---
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout title="Page not found" description="That page doesn't exist.">
  <section class="section">
    <div class="container prose" style="text-align:center;">
      <p class="eyebrow">404</p>
      <h1>Page not found</h1>
      <p class="lead">That page doesn't exist or may have moved.</p>
      <p><a class="btn btn-primary" href="/">Back to home</a></p>
    </div>
  </section>
</BaseLayout>
