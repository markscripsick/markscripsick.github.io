---
import { getCollection, render } from 'astro:content';
import BaseLayout from '../../layouts/BaseLayout.astro';
import Gallery from '../../components/Gallery.astro';
import ModelViewer from '../../components/ModelViewer.astro';

export async function getStaticPaths() {
  const projects = await getCollection('projects', ({ data }) => !data.draft);
  return projects.map((project) => ({
    params: { slug: project.id },
    props: { project },
  }));
}

const { project } = Astro.props;
const { data } = project;
const { Content } = await render(project);

const dateLabel = data.date.toLocaleDateString('en-US', {
  year: 'numeric',
  month: 'long',
});
---

<BaseLayout
  title={data.title}
  description={data.summary}
  image={data.heroImage}
>
  <article class="section">
    <div class="container">
      <a class="back" href="/projects">← All projects</a>

      <header class="project-head">
        <p class="eyebrow">{dateLabel}</p>
        <h1>{data.title}</h1>
        <p class="lead">{data.summary}</p>

        {
          data.skills.length > 0 && (
            <ul class="tags" aria-label="Skills">
              {data.skills.map((s) => (
                <li class="chip">{s}</li>
              ))}
            </ul>
          )
        }

        {
          data.externalLink && (
            <p class="ext">
              <a class="btn btn-primary" href={data.externalLink} rel="noopener">
                {data.externalLinkLabel ?? 'View project'} ↗
              </a>
            </p>
          )
        }
      </header>

      {
        data.heroImage && (
          <img
            class="hero-img"
            src={data.heroImage}
            alt={data.heroAlt || data.title}
            width="1200"
            height="675"
            fetchpriority="high"
          />
        )
      }

      <!-- Markdown write-up -->
      <div class="prose body">
        <Content />
      </div>

      <!-- Image gallery (renders only if `gallery` has entries) -->
      <Gallery images={data.gallery} />

      <!--
        FUTURE 3D / CAD EMBED. Renders only when a project sets `embedUrl`
        in its frontmatter (Onshape / Sketchfab / hosted glTF viewer).
        See src/components/ModelViewer.astro to build this out further.
      -->
      {
        data.embedUrl && (
          <section class="model">
            <h2>Interactive model</h2>
            <ModelViewer src={data.embedUrl} title={`${data.title} — 3D model`} />
          </section>
        )
      }
    </div>
  </article>
</BaseLayout>

<style>
  .back {
    display: inline-block;
    margin-bottom: 2rem;
    font-family: var(--font-mono);
    text-transform: uppercase;
    letter-spacing: 0.14em;
    font-size: 0.7rem;
    color: var(--ink-faint);
    text-decoration: none;
    transition: color 0.2s var(--ease);
  }
  .back:hover {
    color: var(--ink);
  }
  .project-head {
    max-width: var(--maxw-prose);
  }
  .tags {
    display: flex;
    flex-wrap: wrap;
    gap: 0.4rem;
    list-style: none;
    margin: 1rem 0 0;
    padding: 0;
  }
  .ext {
    margin-top: 1.25rem;
  }
  .hero-img {
    width: 100%;
    border-radius: var(--radius);
    border: 1px solid var(--border);
    margin: 2rem 0;
    aspect-ratio: 16 / 9;
    object-fit: cover;
  }
  .model {
    margin-top: 2.5rem;
  }
</style>
