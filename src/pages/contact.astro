---
import BaseLayout from '../layouts/BaseLayout.astro';
import { CONTACT } from '../config';

const links = [
  CONTACT.email && {
    label: 'Email',
    value: CONTACT.email,
    href: `mailto:${CONTACT.email}`,
  },
  CONTACT.linkedin && {
    label: 'LinkedIn',
    value: CONTACT.linkedin.replace(/^https?:\/\/(www\.)?/, ''),
    href: CONTACT.linkedin,
  },
  CONTACT.github && {
    label: 'GitHub',
    value: CONTACT.github.replace(/^https?:\/\/(www\.)?/, ''),
    href: CONTACT.github,
  },
].filter(Boolean) as { label: string; value: string; href: string }[];
---

<BaseLayout
  title="Contact"
  description="Get in touch with Mark Scripsick — email, LinkedIn, and GitHub."
>
  <section class="section">
    <div class="container prose">
      <p class="eyebrow">Get in touch</p>
      <h1>Contact</h1>
      <p class="lead">
        I'm open to internships, co-ops, and design-build collaborations. The
        best way to reach me is email.
      </p>

      <ul class="contact-list">
        {
          links.map((link) => (
            <li class="card contact-item">
              <span class="contact-label">{link.label}</span>
              <a href={link.href} rel="me noopener">
                {link.value}
              </a>
            </li>
          ))
        }
      </ul>
    </div>
  </section>
</BaseLayout>

<style>
  .contact-list {
    list-style: none;
    margin: 2.5rem 0 0;
    padding: 0;
    display: grid;
    gap: 0.85rem;
    max-width: 38rem;
  }
  .contact-item {
    display: flex;
    align-items: center;
    gap: 1.25rem;
    padding: 1.15rem 1.4rem;
    transition: border-color 0.2s var(--ease), box-shadow 0.2s var(--ease);
  }
  .contact-item:hover {
    border-color: var(--ink-faint);
    box-shadow: var(--shadow);
  }
  .contact-label {
    font-family: var(--font-mono);
    text-transform: uppercase;
    letter-spacing: 0.14em;
    font-size: 0.66rem;
    color: var(--ink-faint);
    min-width: 5.5rem;
  }
  .contact-item a {
    font-family: var(--font-serif);
    font-size: 1.15rem;
    color: var(--ink);
    text-decoration: none;
    word-break: break-word;
    box-shadow: inset 0 -1px 0 0 var(--border);
    transition: box-shadow 0.2s var(--ease);
  }
  .contact-item a:hover {
    box-shadow: inset 0 -1px 0 0 var(--ink);
  }
</style>
