---
import { getCollection } from 'astro:content';
import BaseLayout from '../layouts/BaseLayout.astro';
import ProjectCard from '../components/ProjectCard.astro';
import { SITE, CONTACT, HERO } from '../config';

const projects = (await getCollection('projects', ({ data }) => !data.draft))
  .sort((a, b) => b.data.date.valueOf() - a.data.date.valueOf());

// Featured projects for the home grid; fall back to the 3 most recent.
const featured = projects.filter((p) => p.data.featured);
const homeProjects = (featured.length ? featured : projects).slice(0, 3);
---

<BaseLayout>
  <!-- ── Split-screen hero ── -->
  <section class="hero" aria-label="Introduction">
    <div class="hero-grid">
      <div class="hero-panel">
        <p class="eyebrow reveal" style="--d: 0.05s">{HERO.eyebrow}</p>
        <h1 class="hero-headline reveal" style="--d: 0.16s">{HERO.headline}</h1>
        <p class="hero-accent serif-italic reveal" style="--d: 0.3s">
          {HERO.accent}
        </p>
        <p class="hero-intro reveal" style="--d: 0.44s">{HERO.intro}</p>
        <div class="hero-actions reveal" style="--d: 0.58s">
          <a class="btn btn-primary" href={HERO.primary.href}>
            {HERO.primary.label}
          </a>
          <a class="btn btn-ghost" href={HERO.secondary.href}>
            {HERO.secondary.label}
          </a>
        </div>
      </div>

      <figure class="hero-figure reveal-img" style="--d: 0.32s">
        <img
          src={HERO.image}
          alt={HERO.imageAlt}
          width="1000"
          height="1200"
          fetchpriority="high"
        />
        {
          HERO.imageCaption && (
            <figcaption class="hero-cap">{HERO.imageCaption}</figcaption>
          )
        }
      </figure>
    </div>
  </section>

  <!-- ── Featured projects ── -->
  <section class="section">
    <div class="container">
      <div class="section-head">
        <div>
          <p class="eyebrow">Selected Work</p>
          <h2>Featured projects</h2>
        </div>
        <a class="see-all" href="/projects">All projects →</a>
      </div>
      <div class="grid-cards">
        {homeProjects.map((project) => <ProjectCard project={project} />)}
      </div>
    </div>
  </section>

  <!-- ── Quick links ── -->
  <section class="section quick">
    <div class="container">
      <p class="eyebrow">Explore</p>
      <h2>Quick links</h2>
      <div class="quick-grid">
        <a class="card quick-card" href="/certifications">
          <h3>Certifications</h3>
          <p>Credentials earned and in progress.</p>
          <span class="quick-arrow" aria-hidden="true">→</span>
        </a>
        <a class="card quick-card" href="/about">
          <h3>About me</h3>
          <p>Background, skills, and résumé.</p>
          <span class="quick-arrow" aria-hidden="true">→</span>
        </a>
        <a class="card quick-card" href="/contact">
          <h3>Contact</h3>
          <p>Email, LinkedIn, and GitHub.</p>
          <span class="quick-arrow" aria-hidden="true">→</span>
        </a>
        {
          CONTACT.github && (
            <a class="card quick-card" href={CONTACT.github} rel="me noopener">
              <h3>GitHub</h3>
              <p>Code and build files.</p>
              <span class="quick-arrow" aria-hidden="true">
                ↗
              </span>
            </a>
          )
        }
      </div>
    </div>
  </section>
</BaseLayout>

<style>
  /* ── Hero: full-bleed split ── */
  .hero {
    border-bottom: 1px solid var(--border-soft);
  }
  .hero-grid {
    display: grid;
    grid-template-columns: 1.05fr 0.95fr;
    min-height: min(86vh, 840px);
  }
  .hero-panel {
    display: flex;
    flex-direction: column;
    justify-content: center;
    padding-block: clamp(3rem, 7vw, 6rem);
    /* align left text near the page edge with comfortable inset */
    padding-inline: clamp(1.5rem, 6vw, 6rem) clamp(1.5rem, 4vw, 4rem);
  }
  .hero-headline {
    font-size: clamp(3rem, 8.5vw, 6rem);
    line-height: 0.96;
    letter-spacing: -0.04em;
    margin: 0;
  }
  .hero-accent {
    font-size: clamp(1.5rem, 3.6vw, 2.4rem);
    line-height: 1.12;
    color: var(--ink-soft);
    margin: 0.35em 0 0;
  }
  .hero-intro {
    font-size: 1.2rem;
    line-height: 1.6;
    color: var(--ink-soft);
    max-width: 38ch;
    margin: 1.6rem 0 0;
  }
  .hero-actions {
    display: flex;
    flex-wrap: wrap;
    gap: 0.85rem;
    margin-top: 2.2rem;
  }

  /* Feature image with subtle treatment */
  .hero-figure {
    position: relative;
    margin: 0;
    overflow: hidden;
    background: var(--surface-2);
    border-left: 1px solid var(--border-soft);
  }
  .hero-figure img {
    width: 100%;
    height: 100%;
    object-fit: cover;
  }
  /* soft overlays: cream seam on the left, gentle darkening at the base */
  .hero-figure::after {
    content: '';
    position: absolute;
    inset: 0;
    pointer-events: none;
    background: linear-gradient(
        90deg,
        color-mix(in srgb, var(--bg) 32%, transparent),
        transparent 13%
      ),
      linear-gradient(
        180deg,
        transparent 68%,
        color-mix(in srgb, var(--char) 16%, transparent)
      );
  }
  .hero-cap {
    position: absolute;
    left: 1.1rem;
    bottom: 1.1rem;
    z-index: 1;
    font-family: var(--font-mono);
    text-transform: uppercase;
    letter-spacing: 0.12em;
    font-size: 0.64rem;
    color: var(--accent-contrast);
    background: color-mix(in srgb, var(--char) 72%, transparent);
    backdrop-filter: blur(3px);
    padding: 0.4rem 0.65rem;
    border-radius: 2px;
  }

  @media (max-width: 820px) {
    .hero-grid {
      grid-template-columns: 1fr;
      min-height: 0;
    }
    .hero-panel {
      padding-block: clamp(2.5rem, 9vw, 4rem);
    }
    .hero-figure {
      border-left: 0;
      border-top: 1px solid var(--border-soft);
      aspect-ratio: 4 / 3;
      order: -1; /* image above text on mobile reads well */
    }
  }

  /* ── Staggered page-load reveal ── */
  @keyframes rise {
    from {
      opacity: 0;
      transform: translateY(16px);
    }
    to {
      opacity: 1;
      transform: none;
    }
  }
  @keyframes imgRise {
    from {
      opacity: 0;
      transform: scale(1.035);
    }
    to {
      opacity: 1;
      transform: none;
    }
  }
  .reveal {
    opacity: 0;
    animation: rise 0.7s var(--ease) forwards;
    animation-delay: var(--d, 0s);
  }
  .reveal-img {
    opacity: 0;
    animation: imgRise 0.95s var(--ease) forwards;
    animation-delay: var(--d, 0s);
  }
  @media (prefers-reduced-motion: reduce) {
    .reveal,
    .reveal-img {
      animation: none;
      opacity: 1;
      transform: none;
    }
  }

  /* ── Section heads ── */
  .section-head {
    display: flex;
    align-items: flex-end;
    justify-content: space-between;
    gap: 1rem;
    margin-bottom: 2rem;
  }
  .section-head h2 {
    margin: 0;
  }
  .see-all {
    font-family: var(--font-mono);
    text-transform: uppercase;
    letter-spacing: 0.14em;
    font-size: 0.72rem;
    color: var(--ink-soft);
    text-decoration: none;
    white-space: nowrap;
    padding-bottom: 0.25rem;
    box-shadow: inset 0 -1px 0 0 var(--border);
    transition: box-shadow 0.2s var(--ease), color 0.2s var(--ease);
  }
  .see-all:hover {
    color: var(--ink);
    box-shadow: inset 0 -1px 0 0 var(--ink);
  }

  /* ── Cards / quick links ── */
  .grid-cards {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(290px, 1fr));
    gap: 1.5rem;
  }
  .quick {
    border-top: 1px solid var(--border-soft);
  }
  .quick h2 {
    margin-bottom: 2rem;
  }
  .quick-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(230px, 1fr));
    gap: 1rem;
  }
  .quick-card {
    position: relative;
    padding: 1.5rem 1.5rem 2.4rem;
    text-decoration: none;
    color: var(--ink);
    transition: transform 0.2s var(--ease), box-shadow 0.2s var(--ease),
      border-color 0.2s var(--ease);
  }
  .quick-card:hover {
    transform: translateY(-3px);
    box-shadow: var(--shadow-lg);
    border-color: var(--ink-faint);
  }
  .quick-card h3 {
    margin: 0 0 0.4rem;
  }
  .quick-card p {
    margin: 0;
    color: var(--ink-soft);
    font-size: 1rem;
  }
  .quick-arrow {
    position: absolute;
    left: 1.5rem;
    bottom: 1.2rem;
    font-family: var(--font-mono);
    color: var(--ink-faint);
    transition: transform 0.2s var(--ease), color 0.2s var(--ease);
  }
  .quick-card:hover .quick-arrow {
    color: var(--ink);
    transform: translateX(4px);
  }
</style>
