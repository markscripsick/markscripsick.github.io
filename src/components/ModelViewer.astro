---
/**
 * ────────────────────────────────────────────────────────────────────────
 *  FUTURE-FRIENDLY 3D / CAD EMBED SLOT  (not built out yet — by design)
 * ────────────────────────────────────────────────────────────────────────
 *  Right now this just embeds whatever URL you put in a project's
 *  `embedUrl` frontmatter field inside a responsive iframe. That already
 *  works today for:
 *    • Onshape public-document share links
 *    • Sketchfab embed URLs
 *    • A hosted glTF viewer page
 *
 *  When you're ready to do something fancier (e.g. a real <model-viewer>
 *  glTF component, or the Onshape embed API), this is the ONE place to
 *  upgrade — the project page already calls it. A sketch of that path:
 *
 *    1. npm install @google/model-viewer
 *    2. import it here and swap the <iframe> for:
 *         <model-viewer src={src} camera-controls auto-rotate ... />
 *       (use the `src` for a .glb/.gltf file you put in /public/models/)
 *
 *  Nothing else in the site needs to change.
 */
interface Props {
  src: string;
  title?: string;
}
const { src, title = '3D model' } = Astro.props;
---

<div class="embed">
  <iframe
    src={src}
    title={title}
    loading="lazy"
    allow="fullscreen; autoplay; xr-spatial-tracking"
    allowfullscreen
  ></iframe>
</div>

<style>
  .embed {
    position: relative;
    width: 100%;
    aspect-ratio: 16 / 9;
    border-radius: var(--radius);
    overflow: hidden;
    border: 1px solid var(--border);
    background: var(--surface-2);
  }
  .embed iframe {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    border: 0;
  }
</style>
