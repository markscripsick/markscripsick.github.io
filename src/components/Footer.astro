---
import { SITE, CONTACT } from '../config';
const year = new Date().getFullYear();
---

<footer class="site-footer">
  <div class="container footer-inner">
    <p class="copy">© {year} {SITE.name}</p>
    <ul class="links">
      {CONTACT.email && (
        <li><a href={`mailto:${CONTACT.email}`}>Email</a></li>
      )}
      {CONTACT.linkedin && (
        <li><a href={CONTACT.linkedin} rel="me noopener">LinkedIn</a></li>
      )}
      {CONTACT.github && (
        <li><a href={CONTACT.github} rel="me noopener">GitHub</a></li>
      )}
    </ul>
  </div>
</footer>

<style>
  .site-footer {
    margin-top: auto;
    border-top: 1px solid var(--border);
    background: var(--surface);
  }
  .footer-inner {
    display: flex;
    flex-wrap: wrap;
    gap: 0.75rem 1.25rem;
    align-items: center;
    justify-content: space-between;
    padding-block: 1.5rem;
  }
  .copy {
    margin: 0;
    color: var(--ink-faint);
    font-size: 0.9rem;
  }
  .links {
    display: flex;
    gap: 1rem;
    list-style: none;
    margin: 0;
    padding: 0;
  }
  .links a {
    color: var(--ink-soft);
    text-decoration: none;
    font-size: 0.9rem;
    font-weight: 500;
  }
  .links a:hover {
    color: var(--accent-ink);
  }
</style>
