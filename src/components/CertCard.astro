---
import type { CollectionEntry } from 'astro:content';

interface Props {
  cert: CollectionEntry<'certifications'>;
}
const { cert } = Astro.props;
const { data } = cert;

const dateLabel = data.date
  ? data.date.toLocaleDateString('en-US', { year: 'numeric', month: 'short' })
  : null;
const inProgress = data.status === 'in-progress';
---

<article class="card cert-card">
  {
    data.logo ? (
      <img
        class="logo"
        src={data.logo}
        alt={`${data.issuer} logo`}
        width="56"
        height="56"
        loading="lazy"
      />
    ) : (
      <div class="logo logo-fallback" aria-hidden="true">
        {data.name.charAt(0)}
      </div>
    )
  }
  <div class="cert-body">
    <h3 class="cert-name">{data.name}</h3>
    <p class="issuer">{data.issuer}</p>
    <div class="meta">
      <span class={`status ${inProgress ? 'status-progress' : 'status-done'}`}>
        {inProgress ? 'In progress' : 'Completed'}
      </span>
      {dateLabel && <span class="date">{dateLabel}</span>}
      {
        data.credentialUrl && (
          <a class="cred" href={data.credentialUrl} rel="noopener">
            Credential ↗
          </a>
        )
      }
    </div>
  </div>
</article>

<style>
  .cert-card {
    display: flex;
    gap: 1.1rem;
    padding: 1.4rem 1.5rem;
    align-items: flex-start;
    transition: border-color 0.2s var(--ease), box-shadow 0.2s var(--ease);
  }
  .cert-card:hover {
    border-color: var(--ink-faint);
    box-shadow: var(--shadow);
  }
  .logo {
    flex: none;
    width: 56px;
    height: 56px;
    border-radius: 4px;
    object-fit: contain;
    background: var(--surface-2);
    border: 1px solid var(--border);
    padding: 7px;
  }
  .logo-fallback {
    display: grid;
    place-items: center;
    font-family: var(--font-serif);
    font-weight: 400;
    font-size: 1.6rem;
    color: var(--ink);
    padding: 0;
  }
  .cert-body {
    min-width: 0;
  }
  .cert-name {
    font-size: 1.25rem;
    line-height: 1.15;
    margin: 0 0 0.35rem;
  }
  .issuer {
    margin: 0 0 0.85rem;
    font-family: var(--font-mono);
    text-transform: uppercase;
    letter-spacing: 0.12em;
    font-size: 0.7rem;
    color: var(--ink-faint);
  }
  .meta {
    display: flex;
    flex-wrap: wrap;
    align-items: center;
    gap: 0.55rem 0.9rem;
  }
  /* Monochrome status badges (no color) */
  .status {
    font-family: var(--font-mono);
    text-transform: uppercase;
    letter-spacing: 0.12em;
    font-size: 0.64rem;
    padding: 0.3rem 0.6rem;
    border-radius: 999px;
  }
  .status-done {
    background: var(--char);
    color: var(--accent-contrast);
  }
  .status-progress {
    background: transparent;
    color: var(--ink);
    border: 1px solid var(--ink-faint);
  }
  .date {
    font-family: var(--font-mono);
    text-transform: uppercase;
    letter-spacing: 0.1em;
    font-size: 0.66rem;
    color: var(--ink-faint);
  }
  .cred {
    font-family: var(--font-mono);
    text-transform: uppercase;
    letter-spacing: 0.12em;
    font-size: 0.66rem;
    color: var(--ink);
    text-decoration: none;
    box-shadow: inset 0 -1px 0 0 var(--border);
    transition: box-shadow 0.2s var(--ease);
  }
  .cred:hover {
    box-shadow: inset 0 -1px 0 0 var(--ink);
  }
</style>
