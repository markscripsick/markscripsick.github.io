---
import { SITE, NAV } from '../config';

const path = Astro.url.pathname;
const isActive = (href: string) =>
  href === '/' ? path === '/' : path.startsWith(href);
---

<header class="site-header">
  <div class="container header-inner">
    <a href="/" class="brand">{SITE.name}</a>

    <nav aria-label="Primary">
      <!-- Mobile menu toggle (CSS-only via the hidden checkbox) -->
      <input type="checkbox" id="nav-toggle" class="nav-toggle" />
      <label for="nav-toggle" class="nav-toggle-btn" aria-hidden="true">
        <span></span><span></span><span></span>
      </label>

      <ul class="nav-list">
        {
          NAV.map((item) => (
            <li>
              <a
                href={item.href}
                aria-current={isActive(item.href) ? 'page' : undefined}
              >
                {item.label}
              </a>
            </li>
          ))
        }
      </ul>
    </nav>
  </div>
</header>

<style>
  .site-header {
    position: sticky;
    top: 0;
    z-index: 50;
    background: color-mix(in srgb, var(--bg) 88%, transparent);
    backdrop-filter: saturate(180%) blur(8px);
    border-bottom: 1px solid var(--border);
  }
  .header-inner {
    display: flex;
    align-items: center;
    justify-content: space-between;
    min-height: 4rem;
  }
  .brand {
    font-weight: 700;
    font-size: 1.1rem;
    letter-spacing: -0.02em;
    color: var(--ink);
    text-decoration: none;
  }
  .nav-list {
    list-style: none;
    display: flex;
    gap: 0.35rem;
    margin: 0;
    padding: 0;
  }
  .nav-list a {
    display: inline-block;
    padding: 0.45rem 0.7rem;
    border-radius: 8px;
    color: var(--ink-soft);
    text-decoration: none;
    font-weight: 500;
    font-size: 0.95rem;
  }
  .nav-list a:hover {
    color: var(--ink);
    background: var(--surface-2);
  }
  .nav-list a[aria-current='page'] {
    color: var(--accent-ink);
    background: color-mix(in srgb, var(--accent) 12%, transparent);
  }

  /* Mobile menu: hidden checkbox toggles the list */
  .nav-toggle,
  .nav-toggle-btn {
    display: none;
  }

  @media (max-width: 640px) {
    .nav-toggle-btn {
      display: inline-flex;
      flex-direction: column;
      justify-content: center;
      gap: 5px;
      width: 44px;
      height: 44px;
      cursor: pointer;
      border-radius: 8px;
      border: 1px solid var(--border);
      background: var(--surface);
      padding: 0 11px;
    }
    .nav-toggle-btn span {
      display: block;
      height: 2px;
      background: var(--ink);
      border-radius: 2px;
    }
    .nav-list {
      position: absolute;
      right: 1.25rem;
      top: 3.6rem;
      flex-direction: column;
      gap: 0.15rem;
      background: var(--surface);
      border: 1px solid var(--border);
      border-radius: var(--radius);
      box-shadow: var(--shadow);
      padding: 0.5rem;
      min-width: 11rem;
      display: none;
    }
    .nav-toggle:checked ~ .nav-list {
      display: flex;
    }
    .nav-list a {
      padding: 0.6rem 0.8rem;
    }
  }
</style>
