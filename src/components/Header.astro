---
import { SITE, NAV } from '../config';

const path = Astro.url.pathname;
const isActive = (href: string) =>
  href === '/' ? path === '/' : path.startsWith(href);
---

<header class="site-header">
  <div class="container header-inner">
    <a href="/" class="brand" aria-label={`${SITE.name} — home`}>
      {
        SITE.headshot && (
          <img
            class="brand-photo"
            src={SITE.headshot}
            alt=""
            width="38"
            height="38"
            loading="eager"
          />
        )
      }
      <span class="brand-name">{SITE.name}</span>
    </a>

    <nav class="nav" aria-label="Primary">
      <input type="checkbox" id="nav-toggle" class="nav-toggle" />
      <label for="nav-toggle" class="nav-toggle-btn" aria-label="Toggle menu">
        <span></span><span></span><span></span>
      </label>

      <ul class="nav-list">
        {
          NAV.map((item) => (
            <li>
              <a
                href={item.href}
                aria-current={isActive(item.href) ? 'page' : undefined}
              >
                {item.label}
              </a>
            </li>
          ))
        }
        <li class="nav-pill-li">
          <a class="nav-pill" href={SITE.resume}>Résumé</a>
        </li>
      </ul>
    </nav>
  </div>
</header>

<style>
  .site-header {
    position: sticky;
    top: 0;
    z-index: 50;
    background: color-mix(in srgb, var(--bg) 82%, transparent);
    backdrop-filter: saturate(160%) blur(10px);
    border-bottom: 1px solid var(--border-soft);
  }
  .header-inner {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 1rem;
    min-height: 4.5rem;
  }

  /* Brand: optional headshot + serif wordmark */
  .brand {
    display: inline-flex;
    align-items: center;
    gap: 0.7rem;
    text-decoration: none;
    color: var(--ink);
  }
  .brand-photo {
    width: 38px;
    height: 38px;
    border-radius: 999px;
    object-fit: cover;
    border: 1px solid var(--border);
    box-shadow: var(--shadow-sm);
  }
  .brand-name {
    font-family: var(--font-serif);
    font-size: 1.15rem;
    letter-spacing: -0.01em;
    white-space: nowrap;
  }

  /* Nav list (mono links) */
  .nav-list {
    list-style: none;
    display: flex;
    align-items: center;
    gap: 1.75rem;
    margin: 0;
    padding: 0;
  }
  .nav-list a {
    font-family: var(--font-mono);
    text-transform: uppercase;
    letter-spacing: 0.14em;
    font-size: 0.72rem;
    font-weight: 500;
    color: var(--ink-faint);
    text-decoration: none;
    padding-block: 0.35rem;
    transition: color 0.2s var(--ease);
  }
  .nav-list a:hover {
    color: var(--ink);
  }
  .nav-list a[aria-current='page'] {
    color: var(--ink);
    box-shadow: inset 0 -1px 0 0 var(--ink);
  }

  /* Dark pill in the corner */
  .nav-pill-li {
    margin-left: 0.25rem;
  }
  .nav-pill {
    font-family: var(--font-mono);
    text-transform: uppercase;
    letter-spacing: 0.14em;
    font-size: 0.72rem;
    font-weight: 500;
    color: var(--accent-contrast) !important;
    background: var(--char);
    padding: 0.6rem 1.1rem;
    border-radius: 999px;
    text-decoration: none;
    transition: background-color 0.2s var(--ease);
  }
  .nav-pill:hover {
    background: var(--char-hover);
  }

  /* Mobile menu toggle */
  .nav-toggle,
  .nav-toggle-btn {
    display: none;
  }

  @media (max-width: 720px) {
    .nav-toggle-btn {
      display: inline-flex;
      flex-direction: column;
      justify-content: center;
      gap: 5px;
      width: 44px;
      height: 44px;
      cursor: pointer;
      border-radius: 999px;
      border: 1px solid var(--border);
      background: var(--surface);
      padding: 0 11px;
    }
    .nav-toggle-btn span {
      display: block;
      height: 1.5px;
      background: var(--ink);
    }
    .nav-list {
      position: absolute;
      right: 1.5rem;
      top: 4rem;
      flex-direction: column;
      align-items: flex-start;
      gap: 1.1rem;
      background: var(--surface);
      border: 1px solid var(--border);
      border-radius: var(--radius);
      box-shadow: var(--shadow-lg);
      padding: 1.4rem 1.6rem;
      min-width: 13rem;
      display: none;
    }
    .nav-toggle:checked ~ .nav-list {
      display: flex;
    }
    .nav-pill-li {
      margin-left: 0;
      margin-top: 0.25rem;
    }
  }
</style>
