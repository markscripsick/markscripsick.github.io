---
import type { CollectionEntry } from 'astro:content';

interface Props {
  project: CollectionEntry<'projects'>;
}
const { project } = Astro.props;
const { data, id } = project;
const skillsAttr = data.skills.join('|'); // used by the Projects filter
const dateLabel = data.date.toLocaleDateString('en-US', {
  year: 'numeric',
  month: 'short',
});
---

<article class="card project-card" data-skills={skillsAttr}>
  <a class="thumb" href={`/projects/${id}/`} tabindex="-1" aria-hidden="true">
    <img
      src={data.heroImage}
      alt={data.heroAlt || ''}
      loading="lazy"
      decoding="async"
      width="800"
      height="500"
    />
  </a>
  <div class="body">
    <p class="meta">{dateLabel}</p>
    <h3 class="title">
      <a href={`/projects/${id}/`}>{data.title}</a>
    </h3>
    <p class="summary">{data.summary}</p>
    {
      data.skills.length > 0 && (
        <ul class="tags" aria-label="Skills">
          {data.skills.map((s) => (
            <li class="chip">{s}</li>
          ))}
        </ul>
      )
    }
    <span class="more" aria-hidden="true">View project →</span>
  </div>
</article>

<style>
  .project-card {
    display: flex;
    flex-direction: column;
    background: var(--surface);
    transition: transform 0.2s var(--ease), box-shadow 0.2s var(--ease),
      border-color 0.2s var(--ease);
  }
  .project-card:hover {
    transform: translateY(-4px);
    box-shadow: var(--shadow-lg);
    border-color: var(--ink-faint);
  }
  .thumb {
    display: block;
    aspect-ratio: 8 / 5;
    background: var(--surface-2);
    overflow: hidden;
    border-bottom: 1px solid var(--border);
  }
  .thumb img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    transition: transform 0.5s var(--ease);
  }
  .project-card:hover .thumb img {
    transform: scale(1.03);
  }
  .body {
    padding: 1.3rem 1.4rem 1.45rem;
    display: flex;
    flex-direction: column;
    gap: 0.55rem;
  }
  .meta {
    font-family: var(--font-mono);
    text-transform: uppercase;
    letter-spacing: 0.16em;
    font-size: 0.66rem;
    color: var(--ink-faint);
    margin: 0;
  }
  .title {
    font-size: 1.45rem;
    line-height: 1.1;
    margin: 0;
  }
  .title a {
    color: var(--ink);
    text-decoration: none;
  }
  .title a:hover {
    text-decoration: underline;
    text-decoration-color: var(--ink-faint);
    text-underline-offset: 0.16em;
  }
  .summary {
    margin: 0;
    color: var(--ink-soft);
    font-size: 1rem;
    line-height: 1.55;
  }
  .tags {
    display: flex;
    flex-wrap: wrap;
    gap: 0.4rem;
    list-style: none;
    margin: 0.25rem 0 0;
    padding: 0;
  }
  .more {
    margin-top: 0.6rem;
    font-family: var(--font-mono);
    text-transform: uppercase;
    letter-spacing: 0.14em;
    font-size: 0.66rem;
    color: var(--ink-faint);
    transition: color 0.2s var(--ease);
  }
  .project-card:hover .more {
    color: var(--ink);
  }
</style>
